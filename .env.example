# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=appdb

# Backend (used inside Docker network)
DATABASE_URL=postgres://postgres:postgres@postgres:5432/appdb?sslmode=disable
PORT=8080

# GitHub integration (metrics)
# Personal access token — strongly recommended (raises the rate limit from 60 to 5000 req/hr)
GITHUB_TOKEN=
# Repository to track, as "owner/repo"
GITHUB_REPO=comet-ml/opik
# How far back metrics look, in days
METRICS_WINDOW_DAYS=90
# A PR is "disengaged" when open longer than (avg time-to-address × this multiplier)
DISENGAGED_MULTIPLIER=2.0
# How long computed metrics are cached in memory (Go duration, e.g. 10m, 1h)
METRICS_CACHE_TTL=10m
